{
  "name": "programmers-loop",
  "version": "0.0.0",
  "private": true,
  "description": "Durable planning and verification loops for coding agents.",
  "license": "MIT",
  "bin": {
    "programmers-loop": "./dist/cli.js"
  },
  "files": [
    "assets",
    "dist",
    "docs",
    "prompts",
    "skills",
    "templates",
    "LICENSE",
    "README.md",
    "programmers-loop.config.yaml"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "bun run fmt:check && bun run lint && bun run typecheck && bun run test && bun run test:examples && bun run build && bun run docs:lint && bun run planning:lint && bun run doctor",
    "cli": "tsx src/cli.ts",
    "doctor": "tsx src/cli.ts doctor",
    "doctor:github": "tsx src/cli.ts doctor --github",
    "docs:lint": "tsx src/cli.ts docs lint",
    "exec-plan:proof": "tsx src/cli.ts exec-plan proof",
    "exec-plan:run": "tsx src/cli.ts exec-plan run",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint src test",
    "planning:lint": "tsx src/cli.ts planning lint",
    "program:advance": "tsx src/cli.ts program advance",
    "program:child-plan": "tsx src/cli.ts program child-plan",
    "prompts:list": "tsx src/cli.ts prompts list",
    "skills:list": "tsx src/cli.ts skills list",
    "standup": "tsx src/cli.ts standup",
    "test": "node --import tsx --test test/**/*.test.ts",
    "test:examples": "node --test examples/**/*.test.mjs",
    "test:proof": "node --import tsx --test test/proof.test.ts",
    "test:workflows": "node --import tsx --test test/workflows.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "tsx": "4.23.1",
    "typescript": "7.0.2"
  },
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=24.0.0"
  },
  "packageManager": "bun@1.3.14"
}
